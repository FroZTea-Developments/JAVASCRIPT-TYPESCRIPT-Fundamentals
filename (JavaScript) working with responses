function getTodoThen() {
  console.log("A: Start getTodoThen");

  fetch("https://jsonplaceholder.typicode.com/todos/1")
    .then(response => {
      console.log("B: got response");
      return response.json();
    })
    .then(data => {
      console.log("C: todo title is", data.title);
    });
}

console.log("1: before calling getTodoThen");
getTodoThen();
console.log("2: after calling getTodoThen");